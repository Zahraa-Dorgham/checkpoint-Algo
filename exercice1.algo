ALGORITHM algorithm_name
VAR
    C : CHAR;
    long: INTEGER := 0 ;
    mot: INTEGER := 1;
    nbvoy:INTEGER := 0;

BEGIN
 
   read(C)

   while (C <> '.') do
        long := long + 1
        if c = ' ' then
        mot := mot + 1
        endif

        if ( c = 'a' or c = 'i' or c = 'e' or c = 'u' or c = 'o' ) then
        nbvoy := nbvoy + 1

        endif

        read(C)
    
    Endwhile

    write (long);
    write (mot);
    nbvoy(nbvoy);
    


END